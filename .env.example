# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# CLAUDE_API_KEY: Required for Anthropic Claude AI API calls.
CLAUDE_API_KEY=""

# OPENCODE_API_KEY: Required for OpenCode (OpenAI) AI API calls.
OPENCODE_API_KEY=""

# OPENAI_API_KEY: Required for OpenAI-compatible API calls.
OPENAI_API_KEY=""

# GITHUB_TOKEN: Required for GitHub integration (PRs, branches, commits).
GITHUB_TOKEN=""

# JULES_API_KEY: Required for Jules agent integration.
JULES_API_KEY=""

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3847"

# ===========================================
# Deep Agents Configuration (OpenAI-Compatible)
# ===========================================
# Model: Any OpenAI-compatible model
DEEP_AGENT_MODEL="gpt-4o"

# Base URL: OpenAI API or compatible endpoint
# Examples:
#   https://api.openai.com/v1 (OpenAI)
#   https://api.anthropic.com/v1 (Anthropic via OpenAI compat)
#   https://api.groq.com/openai/v1 (Groq)
#   http://localhost:11434/v1 (Ollama local)
DEEP_AGENT_BASE_URL="https://api.openai.com/v1"
