# ===========================================
# Auto-Developer Orchestrator Configuration
# ===========================================

# -------------------------------------------
# AI Provider API Keys
# -------------------------------------------
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# CLAUDE_API_KEY: Required for Anthropic Claude AI API calls.
CLAUDE_API_KEY=""

# OPENCODE_API_KEY: Required for OpenCode (OpenAI) AI API calls.
OPENCODE_API_KEY=""

# OPENAI_API_KEY: Required for OpenAI-compatible API calls.
OPENAI_API_KEY=""

# -------------------------------------------
# Integration API Keys
# -------------------------------------------
# GITHUB_TOKEN: Required for GitHub integration (PRs, branches, commits).
GITHUB_TOKEN=""

# JULES_API_KEY: Required for Jules agent integration.
JULES_API_KEY=""

# -------------------------------------------
# Application Configuration
# -------------------------------------------
# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# When using Traefik: http://orchestrator.local
APP_URL="http://orchestrator.local"

# SERVER_PORT: Internal server port (must match Dockerfile)
SERVER_PORT="3847"

# ===========================================
# Deep Agents Configuration (OpenAI-Compatible)
# ===========================================
# Model: Any OpenAI-compatible model
DEEP_AGENT_MODEL="gpt-4o"

# Base URL: OpenAI API or compatible endpoint
# Examples:
#   https://api.openai.com/v1 (OpenAI)
#   https://api.anthropic.com/v1 (Anthropic via OpenAI compat)
#   https://api.groq.com/openai/v1 (Groq)
#   http://localhost:11434/v1 (Ollama local)
DEEP_AGENT_BASE_URL="https://api.openai.com/v1"

# ===========================================
# Shared Infrastructure Configuration
# ===========================================
# These connect to shared-docker-infra services via Traefik

# SHARED_NETWORK_NAME: Name of the shared Docker network
# Must match the network name in shared-docker-infra
SHARED_NETWORK_NAME="shared-infra"

# INFRA_DOMAIN: Domain suffix for Traefik routing
# Default is "local" (e.g., orchestrator.local)
INFRA_DOMAIN="local"

# -------------------------------------------
# LiteLLM Configuration (via shared infra)
# -------------------------------------------
# LITELLM_PROXY_URL: URL to shared LiteLLM proxy
# Default: http://litellm.local (via Traefik)
# For direct access: http://litellm:4000 (internal network)
LITELLM_PROXY_URL="http://litellm.local"

# -------------------------------------------
# Langfuse Observability (via shared infra)
# -------------------------------------------
# Get these keys from http://langfuse.local > Settings > API Keys
# LANGFUSE_PUBLIC_KEY: Langfuse public key (pk-lf-...)
LANGFUSE_PUBLIC_KEY=""

# LANGFUSE_SECRET_KEY: Langfuse secret key (sk-lf-...)
LANGFUSE_SECRET_KEY=""

# LANGFUSE_HOST: Langfuse host URL
# Default: http://langfuse.local (via Traefik)
LANGFUSE_HOST="http://langfuse.local"
