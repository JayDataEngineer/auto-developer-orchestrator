# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# CLAUDE_API_KEY: Required for Anthropic Claude AI API calls.
CLAUDE_API_KEY=""

# OPENCODE_API_KEY: Required for OpenCode (OpenAI) AI API calls.
OPENCODE_API_KEY=""

# OPENAI_API_KEY: Required for OpenAI compatible API calls.
OPENAI_API_KEY=""

# GITHUB_TOKEN: Required for GitHub integration (PRs, branches, commits).
GITHUB_TOKEN=""

# JULES_API_KEY: Required for Jules agent integration.
JULES_API_KEY=""

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3847"

# ===========================================
# Deep Agents Configuration (via LangChain)
# ===========================================
# Model: deepagents handles provider routing automatically
# Examples:
#   "claude-sonnet-4-20250514" (Anthropic - default)
#   "claude-3-7-sonnet-20250219" (Anthropic)
#   "gpt-4o" (OpenAI)
#   "gemini-2.0-flash" (Google)
DEEP_AGENT_MODEL="claude-sonnet-4-20250514"

# API Keys (deepagents reads these from env automatically)
# CLAUDE_API_KEY - For Anthropic models
# OPENAI_API_KEY - For OpenAI models  
# GEMINI_API_KEY - For Google models
