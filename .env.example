# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# CLAUDE_API_KEY: Required for Anthropic Claude AI API calls.
CLAUDE_API_KEY=""

# OPENCODE_API_KEY: Required for OpenCode (OpenAI) AI API calls.
OPENCODE_API_KEY=""

# OPENAI_API_KEY: Required for OpenAI compatible API calls.
OPENAI_API_KEY=""

# GITHUB_TOKEN: Required for GitHub integration (PRs, branches, commits).
GITHUB_TOKEN=""

# JULES_API_KEY: Required for Jules agent integration.
JULES_API_KEY=""

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3847"

# ===========================================
# Deep Agents Configuration
# ===========================================
# Provider: "anthropic", "openai", or "gemini"
DEEP_AGENT_PROVIDER="anthropic"

# Model: Specific model to use (depends on provider)
# Anthropic: "claude-3-7-sonnet-20250219", "claude-3-5-sonnet-20241022", etc.
# OpenAI: "gpt-4o", "gpt-4-turbo", "gpt-3.5-turbo", etc.
# Gemini: "gemini-2.0-flash", "gemini-1.5-pro", etc.
DEEP_AGENT_MODEL="claude-3-7-sonnet-20250219"

# Temperature: 0.0 (deterministic) to 1.0 (creative)
DEEP_AGENT_TEMPERATURE="0"
